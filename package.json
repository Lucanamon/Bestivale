{
  "name": "bestivale",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "npm run dev",
    "dev": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "dev:watch": "concurrently \"npm run watch:backend\" \"npm run start:frontend\"",
    "start:frontend": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 npm run dev --prefix frontend/bestivale-ui",
    "start:backend": "dotnet run --project backend/Bestivale.API/Bestivale.API.csproj",
    "watch:backend": "dotnet watch run --project backend/Bestivale.API/Bestivale.API.csproj"
  },
  "packageManager": "npm@11.6.2",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0"
  }
}
